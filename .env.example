NODE_ENV=development
PORT=3000

# --- Credenciais locais (alinhar com docker-compose.yml) ---
GHORG_POSTGRES_PASSWORD=ghorg_local_postgres
GHORG_RABBITMQ_PASSWORD=ghorg_local_rabbit

# PostgreSQL: usuário ghorg_api_svc, database ghorg_requests_db
DATABASE_URL=postgresql://ghorg_api_svc:ghorg_local_postgres@localhost:5432/ghorg_requests_db

# MongoDB: database ghorg_scrape_warehouse (perfis parseados do GitHub)
MONGODB_URI=mongodb://localhost:27017/ghorg_scrape_warehouse

# RabbitMQ: usuário ghorg_queue_svc (painel http://localhost:15672)
RABBITMQ_URL=amqp://ghorg_queue_svc:ghorg_local_rabbit@localhost:5672

# Opcional: proxies HTTP(S) separados por vírgula (Crawlee rotaciona)
# GHORG_PROXY_URLS=http://user:pass@proxy.example:8080

# Recomendado ao testar várias orgs grandes: PAT GitHub (limite 5k req/h).
# Sem token, a API pode devolver 403 no meio da paginação de membros → stats.people fica null.
# GHORG_GITHUB_TOKEN=
